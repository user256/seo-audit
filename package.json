{
  "name": "seo-audit",
  "version": "0.1.0",
  "private": true,
  "description": "Manifest V3 Chrome extension for local-first technical SEO audits of the active tab",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "package:check": "node scripts/package-check.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "2.7.0",
    "@eslint/js": "9.30.1",
    "@types/chrome": "0.0.326",
    "@types/node": "22.15.32",
    "@vitest/coverage-v8": "3.2.4",
    "eslint": "9.30.1",
    "eslint-config-prettier": "10.1.5",
    "fake-indexeddb": "6.0.1",
    "globals": "16.3.0",
    "jsdom": "26.1.0",
    "prettier": "3.6.2",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.1",
    "vite": "6.3.5",
    "vitest": "3.2.4",
    "zod": "3.25.67"
  }
}
